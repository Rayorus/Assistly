# Assistly Configuration

# Gemini API
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Vision model (for screen analysis + guidance)
# gemini-2.0-flash = 1500 req/day free | gemini-2.5-flash = 20 req/day free
VISION_MODEL=gemini-2.0-flash

# Text model (for fast chat without screenshots)
TEXT_MODEL=gemini-2.0-flash

# Voice settings
VOICE_ENABLED=true
SPEECH_RATE=175
